# ─── Copier vers .env et remplir les valeurs ───────────────────────
# Ne jamais committer .env dans Git !

# Django
DJANGO_SECRET_KEY=your-secret-key-here-generate-with-python
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_DEBUG=True

# Base de données
DATABASE_URL=postgres://lily:lily_dev_password@localhost:5432/lily_florist

# CORS — URLs autorisées (séparées par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Hôtes autorisés
ALLOWED_HOSTS=localhost,127.0.0.1

# Email (optionnel en dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=dev@lily-florist.local
